# NoneBot2 配置
HOST=127.0.0.1
PORT=8080
SUPERUSERS=["你的QQ号"]
NICKNAME=["MarsAI"]
COMMAND_START=[""]

# AI 功能配置
# DeepSeek API 密钥（用于云端模型）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# B站下载器配置（可选）
# 如果需要下载高清或会员视频，可以在 ~/.yt-dlp/cookies.txt 放置 cookies
# BILIBILI_COOKIES_PATH=~/.yt-dlp/cookies.txt

# 日志级别
LOG_LEVEL=INFO